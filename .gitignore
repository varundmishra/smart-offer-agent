# ── Secrets / environment ────────────────────────────────────────────────────
# .env may contain GCP_PROJECT and (less ideally) service-account keys —
# never commit. The .env.example file IS committed as the template.
.env
.env.local
.env.*.local
*.pem
*-key.json
service-account*.json
gcloud-credentials.json

# ── Deploy artifacts ──────────────────────────────────────────────────────────
# Resource name is generated by deploy_agent.sh; don't pin it in git
scripts/agent_engine_resource.txt

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs / scratch ────────────────────────────────────────────────────────────
*.log
logs/
tmp/
.scratch/

# ── Working docs (not for sharing) ────────────────────────────────────────────
# Implementation tracker — local working doc, not shipped with the repo.
PLAN.md

# Note: data/seed/*.csv ARE committed — they're small (~70 KB), reproducible
# via scripts/generate_seed_data.py, and let teammates run the agent without
# regenerating. Uncomment below if seed churn becomes noisy in PRs.
# data/seed/*.csv
