# Smart Offer Agent — environment. Copy to .env and fill in.
# .env is auto-loaded by `adk web` (current directory), and by Agent Engine at deploy time.

# ── Vertex AI routing ────────────────────────────────────────────────────────
# Routes Gemini calls through Vertex AI instead of Google AI Studio.
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# ── GCP project + region ─────────────────────────────────────────────────────
# Either GCP_* or GOOGLE_CLOUD_* names work — config.py honours both, GCP_* wins
# if both are set.
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# GCP_PROJECT=your-project-id
# GCP_REGION=us-central1

# ── BigQuery dataset (where the 3 tables live) ───────────────────────────────
# BQ_DATASET=smart_offer_ds

# ── Optional overrides ───────────────────────────────────────────────────────
# AGENT_DISPLAY_NAME="Smart Offer Modeler A-209"
# LOG_NAME=smart-offer-agent
